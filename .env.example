# BIF.TV — environment variables template
# Copy to .env.local and fill in real values.

# Supabase (new key format from late 2024+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Mux
# - TOKEN_ID/SECRET: API access token (Settings -> Access Tokens)
# - SIGNING_KEY_ID/PRIVATE: for signed playback URLs (Settings -> Signing Keys)
#   MUX_SIGNING_KEY_PRIVATE is base64-encoded PEM (decode on server)
# - WEBHOOK_SECRET: from Settings -> Webhooks after creating endpoint
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=
MUX_WEBHOOK_SECRET=

# Admin (any random string; rotate before production)
ADMIN_API_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (email)
RESEND_API_KEY=

# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://biftv.vercel.app

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=2097706464136548

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-SRE84SBD8K
